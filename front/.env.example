# Base URL for the backend API behind nginx (e.g. http://127.0.0.1/api)
VITE_API_BASE_URL=http://127.0.0.1/api

# Base URL for OAuth entrypoints (e.g. http://127.0.0.1)
VITE_OAUTH_BASE_URL=http://127.0.0.1

# Base URL for product/live images stored in MinIO or object storage
VITE_STORAGE_BASE_URL=http://127.0.0.1:9000/live-commerce-bucket/

# Toggle mock API usage (true uses local mocks, false calls backend)
VITE_USE_MOCK_API=true

# API request timeout in milliseconds
VITE_API_TIMEOUT_MS=10000ch

